{
    "env": {
        "es2021": true,
        "node": true,
        "jest": true
    },
    "extends": [
        "standard"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 11,
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "rules": {
        "no-unused-vars": "off",
        "indent": "off",
        "no-tabs": "off",
        "comma-dangle": "off",
        "space-before-function-paren": "off",
        "no-trailing-spaces": "off",
        "import/first": "off",
        "camelcase": "off"
    }
}
